generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== AUTH ==========
model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(CRM)
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  repairOrders  RepairOrder[] @relation("CreatedBy")
  leads         Lead[]
  branches      UserBranch[]
}

enum Role {
  ADMIN
  WAREHOUSE
  WORKSHOP
  SALES
  CRM
}

model UserBranch {
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String
  address      String?
  phone        String?
  users        UserBranch[]
  productBranches ProductBranch[]
  repairOrders RepairOrder[]
  leads        Lead[]
  vehicles     Vehicle[]
  technicians  Technician[]
  customers    Customer[]
  znsLogs      ZnsLog[]
  loyaltyTx    LoyaltyTransaction[]
  partsRequisitions PartsRequisition[]
  inventoryOrders InventoryOrder[]
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ========== INVENTORY ==========
model Product {
  id               Int           @id @default(autoincrement())
  sku              String        @unique
  name             String
  parentId         Int?
  parent           Product?      @relation("ProductHierarchy", fields: [parentId], references: [id])
  children         Product[]     @relation("ProductHierarchy")
  category         String        @default("General")
  unit             String        // Chai, Cái, Bộ...
  conversionUnit   String?       // Thùng, Thanh...
  conversionFactor Int           @default(1)
  status           String        @default("ACTIVE")
  prices           Price[]
  stockMovements   StockMovement[]
  orderItems       OrderItem[]
  partsRequisitionItems PartsRequisitionItem[]
  productBranches  ProductBranch[]
  isDeleted        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([sku])
  @@index([parentId])
  @@index([category])
}

model ProductBranch {
  id               Int       @id @default(autoincrement())
  productId        Int
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId         Int
  branch           Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stockCount       Float     @default(0)
  reservedStock    Float     @default(0)
  stockMin         Float     @default(0)
  stockMax         Float     @default(100)
  movingAvgCost    Decimal   @default(0)
  lastImportDate   DateTime?

  @@unique([productId, branchId])
  @@index([productId])
  @@index([branchId])
}

model Price {
  id        Int      @id @default(autoincrement())
  productId Int
  type      String   // RETAIL, WHOLESALE, INSURANCE
  amount    Decimal
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, type])
}

model StockMovement {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  type          String   // IMPORT, EXPORT
  quantity      Float
  unitCost      Decimal  @default(0)
  totalCost     Decimal  @default(0)
  reason        String?
  relatedRoId   Int?
  inventoryOrderId Int?
  inventoryOrder InventoryOrder? @relation(fields: [inventoryOrderId], references: [id], onDelete: Cascade)
  createdBy     String
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([inventoryOrderId])
}

model InventoryOrder {
  id            Int             @id @default(autoincrement())
  code          String          @unique
  customerId    Int?
  customer      Customer?       @relation(fields: [customerId], references: [id])
  type          String          // EXPORT_RETAIL, EXPORT_WHOLESALE, INTERNAL
  totalAmount   Decimal         @default(0)
  paidAmount    Decimal         @default(0)
  debtAmount    Decimal         @default(0)
  status        String          @default("PAID") // PAID, DEBT, CANCELLED
  reason        String?
  movements     StockMovement[]
  branchId      Int?
  branch        Branch?         @relation(fields: [branchId], references: [id])
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([customerId])
  @@index([branchId])
  @@index([createdAt])
}

// ========== WORKSHOP ==========
model Technician {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  name            String
  phone           String?
  status          String           @default("IDLE") // IDLE, WORKING
  commissionRate  Float            @default(10)
  repairOrders    RepairOrder[]
  performances    TechPerformance[]
  branchId        Int?
  branch          Branch?          @relation(fields: [branchId], references: [id])
  createdAt       DateTime         @default(now())

  @@index([branchId])
}

model RepairOrder {
  id            Int           @id @default(autoincrement())
  customerId    Int
  customer      Customer      @relation(fields: [customerId], references: [id])
  plateNumber   String
  vehicleModel  String?
  kmIn          Int           @default(0)
  symptoms      String?
  status        String        @default("PENDING") // PENDING, DIAGNOSING, DOING, WAITING_PARTS, DONE, DELIVERED
  technicianId  Int?
  technician    Technician?   @relation(fields: [technicianId], references: [id])
  createdById   Int?
  createdBy     User?         @relation("CreatedBy", fields: [createdById], references: [id])
  items         OrderItem[]
  laborCost     Decimal       @default(0)
  partsCost     Decimal       @default(0)
  totalAmount   Decimal       @default(0)
  paidAmount    Decimal       @default(0)
  debtAmount    Decimal       @default(0)
  photos        String[]
  completedAt   DateTime?
  partsRequisitions PartsRequisition[]
  branchId      Int?
  branch        Branch?       @relation(fields: [branchId], references: [id])
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([plateNumber])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([branchId])
}

model OrderItem {
  id            Int         @id @default(autoincrement())
  repairOrderId Int
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Float
  unitPrice     Decimal
  totalPrice    Decimal
}

model TechPerformance {
  id              Int        @id @default(autoincrement())
  technicianId    Int
  technician      Technician @relation(fields: [technicianId], references: [id])
  repairOrderId   Int
  commissionAmount Decimal
  date            DateTime   @default(now())
}

// ========== VEHICLE SALES ==========
model Vehicle {
  id              Int      @id @default(autoincrement())
  vin             String   @unique
  engineNumber    String?
  model           String
  variant         String?
  color           String?
  year            Int
  status          String   @default("AVAILABLE") // AVAILABLE, RESERVED, INCOMING, SOLD
  listPrice       Decimal
  floorPrice      Decimal
  paidAmount      Decimal   @default(0)
  debtAmount      Decimal   @default(0)
  image           String?
  customerId      Int?
  customer        Customer? @relation(fields: [customerId], references: [id])
  bankStatus      String?
  plateStatus     String?
  plateCost       Decimal?  @default(0)
  accessoriesJson String?   @default("[]")
  notes           String?
  branchId        Int?
  branch          Branch?   @relation(fields: [branchId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vin])
  @@index([status])
  @@index([branchId])
}

// ========== CRM ==========
model Customer {
  id             Int              @id @default(autoincrement())
  name           String
  phone          String           @unique
  email          String?
  address        String?
  source         String           @default("WALKIN") // FACEBOOK, WEBSITE, WALKIN, REFERRAL
  loyaltyPoints  Int              @default(0)
  totalSpent     Decimal          @default(0)
  totalDebt      Decimal          @default(0)
  lastVisit      DateTime?
  birthday       DateTime?
  vehiclePlates  String[]
  tags           String[]
  repairOrders   RepairOrder[]
  inventoryOrders InventoryOrder[]
  vehicles       Vehicle[]
  leads          Lead[]
  znsLogs        ZnsLog[]
  loyaltyTx      LoyaltyTransaction[]
  branchId       Int?
  branch         Branch?          @relation(fields: [branchId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([phone])
  @@index([lastVisit])
  @@index([branchId])
}

model Lead {
  id            Int      @id @default(autoincrement())
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  name          String
  phone         String
  source        String   @default("WALKIN")
  status        String   @default("NEW") // NEW, CONSULTING, POTENTIAL, CONVERTED, LOST
  interest      String?
  assignedToId  Int?
  assignedTo    User?    @relation(fields: [assignedToId], references: [id])
  notes         String?
  branchId      Int?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([branchId])
}

model ZnsLog {
  id            Int      @id @default(autoincrement())
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id])
  phone         String
  messageType   String   // THANK_YOU, BIRTHDAY, MAINTENANCE, PROMOTION
  templateId    String?
  content       String
  status        String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  error         String?
  branchId      Int?
  branch        Branch?  @relation(fields: [branchId], references: [id])
  sentAt        DateTime @default(now())

  @@index([branchId])
}

model LoyaltyTransaction {
  id            Int      @id @default(autoincrement())
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id])
  type          String   // EARN, REDEEM
  points        Int
  description   String?
  relatedRoId   Int?
  branchId      Int?
  branch        Branch?  @relation(fields: [branchId], references: [id])
  createdAt     DateTime @default(now())

  @@index([branchId])
}

model PartsRequisition {
  id            Int                    @id @default(autoincrement())
  repairOrderId Int
  repairOrder   RepairOrder            @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  branchId      Int
  branch        Branch                 @relation(fields: [branchId], references: [id])
  status        String                 @default("APPROVED") // APPROVED (immediately processed and deducted)
  reason        String?
  createdBy     String
  createdAt     DateTime               @default(now())
  items         PartsRequisitionItem[]

  @@index([repairOrderId])
  @@index([branchId])
}

model PartsRequisitionItem {
  id            Int              @id @default(autoincrement())
  requisitionId Int
  requisition   PartsRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product          @relation(fields: [productId], references: [id])
  quantity      Float

  @@index([requisitionId])
  @@index([productId])
}

// ========== SYSTEM CONFIG ==========
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
